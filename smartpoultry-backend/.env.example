# ─────────────────────────────────────────────────────────────
#  SmartPoultry Backend — Environment Variables Template
#
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in the values for your local environment
#    3. Never commit .env to version control
# ─────────────────────────────────────────────────────────────


# ── Database ──────────────────────────────────────────────────
# PostgreSQL connection string used by Prisma
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/smartpoultry"


# ── Authentication ────────────────────────────────────────────
# Secret key used to sign and verify JWT tokens
# Use a long, random string (e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET="your_jwt_secret_here"


# ── Server ────────────────────────────────────────────────────
# Port the Express API server listens on (default: 3000)
PORT=3000


# ── CORS ──────────────────────────────────────────────────────
# URL of the frontend client — used to allow cross-origin requests
CLIENT_URL="http://localhost:5173"
